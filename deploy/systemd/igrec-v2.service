[Unit]
Description=igrec v2 beta (parallel to production)
After=network-online.target
Wants=network-online.target

[Service]
User=igrec
Group=igrec
EnvironmentFile=/opt/igrec-v2/.env
Environment=UPLOAD_DIR=/opt/igrec-v2/data/uploads
ExecStart=/opt/igrec-v2/bin/igrec
Restart=always
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/igrec-v2/data

[Install]
WantedBy=multi-user.target
